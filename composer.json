{
    "name": "whoiscrm/whois-crm",
    "description": "WHOIS Data CRM — Subscription-based data distribution platform for WordPress",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "stripe/stripe-php": "^16.0",
        "dompdf/dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "WhoisCRM\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
